<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mi Perfil — Priority Flow</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:system-ui,-apple-system,'Segoe UI',Roboto,sans-serif;background:#0a0a1a;color:#e2e8f0;min-height:100vh;overflow-x:hidden}

  .sidebar{position:fixed;top:0;left:0;width:240px;height:100vh;background:var(--bg-sidebar);border-right:1px solid var(--border);padding:0;overflow-y:auto;z-index:100;transition:transform .3s cubic-bezier(.4,0,.2,1)}
  .sidebar::-webkit-scrollbar{width:4px}
  .sidebar::-webkit-scrollbar-thumb{background:#4c1d95;border-radius:4px}
  .sidebar .logo{padding:24px 20px 16px;border-bottom:1px solid rgba(76,29,149,.4)}
  .sidebar .logo::after{content:'';position:absolute;bottom:-1px;left:20%;width:60%;height:1px;background:linear-gradient(90deg,transparent,#a855f7,transparent)}
  .sidebar .logo h2{font-size:15px;font-weight:900;color:white;letter-spacing:2px;background:linear-gradient(135deg,#fff 60%,#a855f7);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
  .sidebar .logo p{font-size:10px;color:#7c3aed;margin-top:2px;letter-spacing:.1em}
  .sidebar .role-tag{margin:14px 20px;background:linear-gradient(135deg,#1e3a5f,#1d4ed8);color:#93c5fd;font-size:10px;font-weight:700;padding:5px 12px;border-radius:20px;display:inline-flex;align-items:center;gap:6px;border:1px solid rgba(96,165,250,.3);box-shadow:0 0 20px rgba(29,78,216,.2)}
  .sidebar .role-tag i{font-size:10px}
  .nav-section{font-size:9px;font-weight:700;color:#4c1d95;text-transform:uppercase;letter-spacing:.12em;padding:16px 20px 6px}
  .sidebar a{display:flex;align-items:center;gap:10px;padding:10px 20px;color:#8b7cb8;text-decoration:none;font-size:13px;border-left:3px solid transparent;transition:all .2s ease;position:relative;margin:1px 8px;border-radius:8px}
  .sidebar a i{width:18px;text-align:center;font-size:14px;transition:transform .2s}
  .sidebar a:hover{background:rgba(109,40,217,.15);color:white;border-left-color:#a855f7}
  .sidebar a.active{background:rgba(109,40,217,.2);color:white;border-left-color:#a855f7;box-shadow:inset 0 0 20px rgba(168,85,247,.05)}
  .sidebar .logout{position:sticky;bottom:0;padding:14px 20px;border-top:1px solid rgba(76,29,149,.4);margin-top:16px;background:linear-gradient(0deg,#1a0533 60%,transparent)}
  .sidebar .logout a{color:#ef4444;border-left-color:transparent}
  .sidebar .logout a:hover{background:rgba(239,68,68,.1);color:#fca5a5}

  .main{margin-left:240px;min-height:100vh;position:relative}

  .topbar{display:flex;justify-content:space-between;align-items:center;padding:16px 32px;border-bottom:1px solid rgba(76,29,149,.2);background:rgba(18,0,36,.5);backdrop-filter:blur(12px);position:sticky;top:0;z-index:50}
  .topbar h2{font-size:16px;font-weight:700;color:white;display:flex;align-items:center;gap:10px}
  .topbar h2 i{color:#a855f7;font-size:16px}
  .topbar .user{font-size:12px;color:#93c5fd;background:rgba(30,58,95,.5);padding:6px 16px 6px 12px;border-radius:20px;border:1px solid rgba(96,165,250,.3);display:flex;align-items:center;gap:8px}
  .topbar .user i{color:#60a5fa;font-size:10px}

  .container{max-width:560px;margin:0 auto;padding:32px}

  .card{background:linear-gradient(135deg,#140028,#1f0540);border:1px solid rgba(109,40,217,.25);border-radius:16px;padding:32px;box-shadow:0 8px 32px rgba(109,40,217,.15)}
  .avatar{width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,#7c3aed,#a855f7);display:flex;align-items:center;justify-content:center;font-size:28px;color:white;font-weight:700;margin:0 auto 16px;box-shadow:0 4px 20px rgba(124,58,237,.3)}
  .card h2{text-align:center;font-size:20px;color:white;margin-bottom:4px}
  .card .sub{text-align:center;font-size:12px;color:#4c1d95;margin-bottom:24px}
  label{display:block;color:#6d28d9;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px;margin-top:16px}
  label:first-child{margin-top:0}
  label i{margin-right:4px}
  input{width:100%;padding:11px 14px;background:rgba(15,5,32,.6);border:1.5px solid rgba(76,29,149,.5);border-radius:10px;color:white;font-size:14px;transition:all .2s;outline:none}
  input:focus{border-color:#a855f7;box-shadow:0 0 0 3px rgba(168,85,247,.15)}
  input::placeholder{color:#4c1d95}
  input:disabled{opacity:.4;cursor:not-allowed}
  .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;width:100%;margin-top:24px;padding:12px;background:linear-gradient(135deg,#7c3aed,#a855f7);color:white;font-size:14px;font-weight:700;border:none;border-radius:10px;cursor:pointer;letter-spacing:.05em;transition:all .2s;box-shadow:0 4px 16px rgba(124,58,237,.3)}
  .btn:hover{transform:translateY(-2px);box-shadow:0 6px 24px rgba(124,58,237,.4)}
  .btn-secondary{background:rgba(109,40,217,.15);color:#c4b5fd;border:1px solid rgba(109,40,217,.3);box-shadow:none;margin-top:12px;font-size:13px}
  .btn-secondary:hover{background:rgba(109,40,217,.25);color:white;box-shadow:none}
  .msg{padding:12px 16px;border-radius:10px;font-size:13px;margin-bottom:20px;display:flex;align-items:center;gap:10px}
  .success{background:rgba(22,101,52,.15);color:#4ade80;border:1px solid rgba(22,101,52,.4)}
  .error{background:rgba(153,27,27,.15);color:#f87171;border:1px solid rgba(153,27,27,.4)}
  .divider{border:none;border-top:1px solid rgba(76,29,149,.3);margin:20px 0}
  .info-field{background:rgba(15,5,32,.4);border-radius:8px;padding:10px 14px;color:#a78bfa;font-size:13px;display:flex;align-items:center;gap:8px}
  .info-field i{color:#4c1d95;width:18px}

  .menu-toggle{display:none;position:fixed;top:16px;left:16px;z-index:200;background:#2d1054;border:1px solid #6d28d9;color:white;width:40px;height:40px;border-radius:10px;cursor:pointer;font-size:18px;align-items:center;justify-content:center}
  .sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:99}
  .sidebar-overlay.show{display:block}

  @media(max-width:768px){
    .menu-toggle{display:flex}
    .sidebar{transform:translateX(-100%)}
    .sidebar.open{transform:translateX(0)}
    .sidebar-overlay.show{display:block}
    .main{margin-left:0}
    .container{padding:16px}
    .topbar{padding:12px 16px}
  }
</style>
</head>
<body>
<button class="menu-toggle" id="menuToggle"><i class="fas fa-bars"></i></button>
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<div class="sidebar" id="sidebar">
  <div class="logo">
    <h2>PRIORITY FLOW</h2>
    <p>Mi Perfil</p>
  </div>
  <span class="role-tag"><i class="fas fa-user"></i> CLIENTE</span>
  <div class="nav-section">Navegacion</div>
  <a href="/cliente?u=<%= usuario.username %>"><i class="fas fa-inbox"></i> Bandeja</a>
  <a href="/cliente/perfil?u=<%= usuario.username %>" class="active"><i class="fas fa-user-gear"></i> Perfil</a>
  <div class="logout"><a href="/logout"><i class="fas fa-right-from-bracket"></i> Cerrar sesion</a></div>
</div>

<div class="main">
  <div class="topbar">
    <h2><i class="fas fa-user-gear"></i> Mi Perfil</h2>
    <span class="user"><i class="fas fa-circle"></i> <%= usuario.nombre %> <%= usuario.apellido %></span>
  </div>

  <div class="container">
    <div class="card">
      <% if (typeof msg !== 'undefined' && msg && !msg.includes('Error')) { %>
        <div class="msg success"><i class="fas fa-check-circle"></i> <%= msg %></div>
      <% } else if (typeof msg !== 'undefined' && msg && msg.includes('Error')) { %>
        <div class="msg error"><i class="fas fa-exclamation-circle"></i> <%= msg %></div>
      <% } %>

      <div class="avatar"><%= usuario.nombre.charAt(0).toUpperCase() %></div>
      <h2><%= usuario.nombre %> <%= usuario.apellido %></h2>
      <div class="sub">@<%= usuario.username %></div>

      <form action="/cliente/perfil?u=<%= usuario.username %>" method="POST">
        <label><i class="fas fa-user"></i> Nombre</label>
        <input type="text" name="nombre" value="<%= usuario.nombre %>" required>

        <label><i class="fas fa-user"></i> Apellido</label>
        <input type="text" name="apellido" value="<%= usuario.apellido %>" required>

        <label><i class="fas fa-envelope"></i> Correo electronico</label>
        <input type="email" name="correo" value="<%= persona.documento %>" required>

        <hr class="divider">

        <label><i class="fas fa-at"></i> Nombre de usuario</label>
        <div class="info-field"><i class="fas fa-user-circle"></i> @<%= usuario.username %></div>

        <label><i class="fas fa-key"></i> Nueva contraseña (dejar vacio para mantener)</label>
        <input type="password" name="password" placeholder="Nueva contraseña">

        <label><i class="fas fa-check"></i> Confirmar contraseña</label>
        <input type="password" name="confirm" placeholder="Repite la nueva contraseña">

        <button class="btn" type="submit"><i class="fas fa-save"></i> Guardar cambios</button>
      </form>

      <a href="/cliente?u=<%= usuario.username %>" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Volver a la bandeja</a>
    </div>
  </div>
</div>

<script>
document.getElementById('menuToggle')?.addEventListener('click',()=>{
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('sidebarOverlay').classList.toggle('show');
});
document.getElementById('sidebarOverlay')?.addEventListener('click',()=>{
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sidebarOverlay').classList.remove('show');
});
</script>
</body>
</html>
