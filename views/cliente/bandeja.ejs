<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mi Bandeja — Priority Flow</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:system-ui,-apple-system,'Segoe UI',Roboto,sans-serif;background:#0a0a1a;color:#e2e8f0;min-height:100vh;overflow-x:hidden}

  .sidebar{position:fixed;top:0;left:0;width:240px;height:100vh;background:var(--bg-sidebar);border-right:1px solid var(--border);padding:0;overflow-y:auto;z-index:100;transition:transform .3s cubic-bezier(.4,0,.2,1)}
  .sidebar::-webkit-scrollbar{width:4px}
  .sidebar::-webkit-scrollbar-thumb{background:#4c1d95;border-radius:4px}
  .sidebar .logo{padding:24px 20px 16px;border-bottom:1px solid rgba(76,29,149,.4)}
  .sidebar .logo::after{content:'';position:absolute;bottom:-1px;left:20%;width:60%;height:1px;background:linear-gradient(90deg,transparent,#a855f7,transparent)}
  .sidebar .logo h2{font-size:15px;font-weight:900;color:white;letter-spacing:2px;background:linear-gradient(135deg,#fff 60%,#a855f7);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
  .sidebar .logo p{font-size:10px;color:#7c3aed;margin-top:2px;letter-spacing:.1em}
  .sidebar .role-tag{margin:14px 20px;background:linear-gradient(135deg,#1e3a5f,#1d4ed8);color:#93c5fd;font-size:10px;font-weight:700;padding:5px 12px;border-radius:20px;display:inline-flex;align-items:center;gap:6px;border:1px solid rgba(96,165,250,.3);box-shadow:0 0 20px rgba(29,78,216,.2)}
  .sidebar .role-tag i{font-size:10px}
  .nav-section{font-size:9px;font-weight:700;color:#4c1d95;text-transform:uppercase;letter-spacing:.12em;padding:16px 20px 6px}
  .sidebar a{display:flex;align-items:center;gap:10px;padding:10px 20px;color:#8b7cb8;text-decoration:none;font-size:13px;border-left:3px solid transparent;transition:all .2s ease;position:relative;margin:1px 8px;border-radius:8px}
  .sidebar a i{width:18px;text-align:center;font-size:14px;transition:transform .2s}
  .sidebar a:hover{background:rgba(109,40,217,.15);color:white;border-left-color:#a855f7}
  .sidebar a.active{background:rgba(109,40,217,.2);color:white;border-left-color:#a855f7;box-shadow:inset 0 0 20px rgba(168,85,247,.05)}
  .sidebar .logout{position:sticky;bottom:0;padding:14px 20px;border-top:1px solid rgba(76,29,149,.4);margin-top:16px;background:linear-gradient(0deg,#1a0533 60%,transparent)}
  .sidebar .logout a{color:#ef4444;border-left-color:transparent}
  .sidebar .logout a:hover{background:rgba(239,68,68,.1);color:#fca5a5}

  .main{margin-left:240px;min-height:100vh;position:relative}

  .topbar{display:flex;justify-content:space-between;align-items:center;padding:16px 32px;border-bottom:1px solid rgba(76,29,149,.2);background:rgba(18,0,36,.5);backdrop-filter:blur(12px);position:sticky;top:0;z-index:50}
  .topbar h2{font-size:16px;font-weight:700;color:white;display:flex;align-items:center;gap:10px}
  .topbar h2 i{color:#a855f7;font-size:16px}
  .topbar .user{font-size:12px;color:#93c5fd;background:rgba(30,58,95,.5);padding:6px 16px 6px 12px;border-radius:20px;border:1px solid rgba(96,165,250,.3);display:flex;align-items:center;gap:8px}
  .topbar .user i{color:#60a5fa;font-size:10px}

  .content{padding:24px 32px;max-width:900px;margin:0 auto}

  .stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:24px}
  .stat{background:linear-gradient(135deg,#140028,#1f0540);border:1px solid rgba(109,40,217,.2);border-radius:14px;padding:18px 16px;text-align:center;transition:all .3s}
  .stat:hover{transform:translateY(-3px);border-color:rgba(168,85,247,.4);box-shadow:0 6px 24px rgba(109,40,217,.15)}
  .stat .n{font-size:26px;font-weight:800;line-height:1.2}
  .stat .l{font-size:9px;text-transform:uppercase;letter-spacing:.08em;margin-top:4px}
  .stat .icon{font-size:20px;margin-bottom:6px;opacity:.7}

  .filtros{display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap}
  .filtro{display:flex;align-items:center;gap:6px;padding:8px 18px;border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;text-decoration:none;border:1px solid rgba(76,29,149,.4);color:#8b7cb8;background:rgba(26,5,51,.5);transition:all .2s}
  .filtro:hover{background:rgba(109,40,217,.15);color:white;border-color:#6d28d9}
  .filtro.active{background:linear-gradient(135deg,#7c3aed,#a855f7);color:white;border-color:transparent;box-shadow:0 4px 16px rgba(124,58,237,.25)}
  .filtro.alta.active{background:linear-gradient(135deg,#991b1b,#dc2626);box-shadow:0 4px 16px rgba(220,38,38,.2)}
  .filtro.media.active{background:linear-gradient(135deg,#92400e,#d97706);box-shadow:0 4px 16px rgba(217,119,6,.2)}
  .filtro.baja.active{background:linear-gradient(135deg,#166534,#16a34a);box-shadow:0 4px 16px rgba(22,163,74,.2)}

  .empty-state{text-align:center;padding:80px 20px;color:#4c1d95}
  .empty-state .big-icon{font-size:56px;margin-bottom:16px;opacity:.5}
  .empty-state p{font-size:15px;margin-bottom:6px}
  .empty-state .sub{font-size:12px;color:#2d1054}

  .msg-card{background:linear-gradient(135deg,#140028,#1a0533);border:1px solid rgba(109,40,217,.2);border-radius:16px;padding:20px 22px;margin-bottom:14px;border-left:4px solid #6d28d9;transition:all .3s;position:relative;overflow:hidden}
  .msg-card::before{content:'';position:absolute;top:-50%;right:-50%;width:100%;height:100%;background:radial-gradient(circle,var(--glow) 0%,transparent 70%);opacity:0;transition:opacity .4s;pointer-events:none}
  .msg-card:hover::before{opacity:1}
  .msg-card:hover{transform:translateY(-2px);border-color:rgba(168,85,247,.4);box-shadow:0 6px 24px rgba(109,40,217,.12)}
  .msg-card.alta{border-left-color:#dc2626;--glow:rgba(220,38,38,.08)}
  .msg-card.media{border-left-color:#d97706;--glow:rgba(217,119,6,.08)}
  .msg-card.baja{border-left-color:#16a34a;--glow:rgba(22,163,74,.08)}
  .msg-card .top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px}
  .msg-card .top .left{flex:1}
  .msg-card .asunto{font-size:16px;font-weight:700;color:white;display:flex;align-items:center;gap:8px}
  .msg-card .meta{display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-top:8px}
  .msg-card .cuerpo{font-size:13px;color:#8b7cb8;line-height:1.7;margin-top:12px;padding-top:12px;border-top:1px solid rgba(45,16,84,.5)}
  .msg-card .canales{margin-top:12px;display:flex;gap:6px;flex-wrap:wrap;align-items:center}
  .msg-card .canales .label{font-size:10px;color:#4c1d95;margin-right:4px;font-weight:600;text-transform:uppercase;letter-spacing:.05em}
  .msg-card .fecha{font-size:11px;color:#4c1d95;white-space:nowrap;display:flex;align-items:center;gap:4px}

  .badge{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:10px;font-weight:700}
  .badge-red{background:rgba(153,27,27,.15);color:#f87171;border:1px solid rgba(153,27,27,.4)}
  .badge-yellow{background:rgba(120,53,15,.15);color:#fbbf24;border:1px solid rgba(120,53,15,.4)}
  .badge-green{background:rgba(22,101,52,.15);color:#4ade80;border:1px solid rgba(22,101,52,.4)}
  .badge-purple{background:rgba(109,40,217,.15);color:#c4b5fd;border:1px solid rgba(109,40,217,.3)}
  .badge-blue{background:rgba(30,64,175,.15);color:#60a5fa;border:1px solid rgba(30,64,175,.3)}
  .priority-dot{width:10px;height:10px;border-radius:50%;display:inline-block}

  .menu-toggle{display:none;position:fixed;top:16px;left:16px;z-index:200;background:#2d1054;border:1px solid #6d28d9;color:white;width:40px;height:40px;border-radius:10px;cursor:pointer;font-size:18px;align-items:center;justify-content:center}
  .sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:99}
  .sidebar-overlay.show{display:block}

  @media(max-width:768px){
    .menu-toggle{display:flex}
    .sidebar{transform:translateX(-100%)}
    .sidebar.open{transform:translateX(0)}
    .sidebar-overlay.show{display:block}
    .main{margin-left:0}
    .content{padding:16px}
    .stats{grid-template-columns:1fr 1fr}
    .topbar{padding:12px 16px}
    .topbar .user span{display:none}
  }
  @media(max-width:480px){.stats{grid-template-columns:1fr}}

  ::-webkit-scrollbar{width:6px}
  ::-webkit-scrollbar-track{background:#0a0a1a}
  ::-webkit-scrollbar-thumb{background:#2d1054;border-radius:4px}
</style>
</head>
<body>
<button class="menu-toggle" id="menuToggle"><i class="fas fa-bars"></i></button>
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<div class="sidebar" id="sidebar">
  <div class="logo">
    <h2>PRIORITY FLOW</h2>
    <p>Bandeja de Notificaciones</p>
  </div>
  <span class="role-tag"><i class="fas fa-user"></i> CLIENTE</span>
  <div class="nav-section">Navegacion</div>
  <a href="/cliente?u=<%= usuario.username %>" class="active"><i class="fas fa-inbox"></i> Bandeja</a>
  <a href="/cliente/perfil?u=<%= usuario.username %>"><i class="fas fa-user-gear"></i> Perfil</a>
  <div class="logout"><a href="/logout"><i class="fas fa-right-from-bracket"></i> Cerrar sesion</a></div>
</div>

<div class="main">
  <div class="topbar">
    <h2><i class="fas fa-inbox"></i> Mi Bandeja</h2>
    <span class="user"><i class="fas fa-circle"></i> <span><%= usuario.nombre %> <%= usuario.apellido %></span></span>
  </div>

  <div class="content">
    <div class="stats">
      <div class="stat">
        <div class="icon">&#128230;</div>
        <div class="n" style="color:#a855f7"><%= mensajes.length %></div>
        <div class="l" style="color:#7c3aed">Total</div>
      </div>
      <div class="stat">
        <div class="icon">&#128308;</div>
        <div class="n" style="color:#f87171"><%= mensajes.filter(m=>m.orden==1).length %></div>
        <div class="l" style="color:#ef4444">Alta Prioridad</div>
      </div>
      <div class="stat">
        <div class="icon">&#128992;</div>
        <div class="n" style="color:#fbbf24"><%= mensajes.filter(m=>m.orden==2).length %></div>
        <div class="l" style="color:#f59e0b">Media</div>
      </div>
      <div class="stat">
        <div class="icon">&#128994;</div>
        <div class="n" style="color:#4ade80"><%= mensajes.filter(m=>m.orden>=3).length %></div>
        <div class="l" style="color:#22c55e">Baja</div>
      </div>
    </div>

    <div class="filtros">
      <a href="/cliente?u=<%= usuario.username %>" class="filtro <%= !filtro?'active':'' %>"><i class="fas fa-layer-group"></i> Todas</a>
      <a href="/cliente?u=<%= usuario.username %>&filtro=alta" class="filtro alta <%= filtro==='alta'?'active':'' %>"><i class="fas fa-arrow-up"></i> Alta prioridad</a>
      <a href="/cliente?u=<%= usuario.username %>&filtro=media" class="filtro media <%= filtro==='media'?'active':'' %>"><i class="fas fa-minus"></i> Media</a>
      <a href="/cliente?u=<%= usuario.username %>&filtro=baja" class="filtro baja <%= filtro==='baja'?'active':'' %>"><i class="fas fa-arrow-down"></i> Baja</a>
    </div>

    <% if (mensajes.length === 0) { %>
      <div class="empty-state">
        <div class="big-icon">&#128229;</div>
        <p>No tienes notificaciones por el momento</p>
        <div class="sub">Cuando recibas mensajes apareceran aqui</div>
      </div>
    <% } %>

    <% mensajes.forEach((m, i) => { %>
    <div class="msg-card <%= m.orden==1?'alta':m.orden==2?'media':'baja' %>" style="animation-delay:<%= i*0.05 %>s">
      <div class="top">
        <div class="left">
          <div class="asunto">
            <span class="priority-dot" style="background:<%= m.orden==1?'#dc2626':m.orden==2?'#d97706':'#16a34a' %>"></span>
            <%= m.asunto %>
          </div>
          <div class="meta">
            <span class="badge badge-purple"><i class="fas fa-tag"></i> <%= m.cat %></span>
            <span class="badge <%= m.orden==1?'badge-red':m.orden==2?'badge-yellow':'badge-green' %>">
              <i class="fas fa-<%= m.orden==1?'arrow-up':m.orden==2?'minus':'arrow-down' %>"></i> <%= m.imp %>
            </span>
            <span class="badge badge-blue"><i class="fas fa-building"></i> <%= m.org %></span>
          </div>
        </div>
        <span class="fecha"><i class="far fa-calendar"></i> <%= new Date(m.fechaCreacion).toLocaleDateString() %> <span style="color:#2d1054"><%= new Date(m.fechaCreacion).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}) %></span></span>
      </div>
      <% if (m.cuerpo) { %>
      <div class="cuerpo"><%= m.cuerpo %></div>
      <% } %>
      <% if (m.canales && m.canales.length > 0) { %>
      <div class="canales">
        <span class="label">Enviado por:</span>
        <% m.canales.forEach(c => { %>
          <span class="badge badge-purple"><i class="fas fa-<%= c==='email'?'envelope':c==='sms'?'comment':c==='whatsapp'?'whatsapp':'bell' %>"></i> <%= c %></span>
        <% }) %>
      </div>
      <% } %>
    </div>
    <% }) %>
  </div>
</div>

<script>
document.getElementById('menuToggle')?.addEventListener('click',()=>{
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('sidebarOverlay').classList.toggle('show');
});
document.getElementById('sidebarOverlay')?.addEventListener('click',()=>{
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sidebarOverlay').classList.remove('show');
});
</script>
</body>
</html>
